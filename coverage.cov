65     	func PortForward(forwarder Forwarder, readych chan struct{}, timeout time.Duration) error {
66     		errchan := make(chan error, 1)
67     	
68     		go func() {
69     			err := forwarder.ForwardPorts()
70     			if err != nil {
71     				errchan <- err
72     			}
73     		}()
74     	
75     		ctx, cancel := context.WithTimeout(context.Background(), timeout)
76     		defer cancel()
77     		for {
78     			select {
79     			case <-ctx.Done():
80     				return errors.New("timeout waiting for port forward")
81     			case errForward := <-errchan:
82     				return errForward
83     			case <-readych:
84     				return nil
85     			}
86     		}
87     	}


66     	func SelectPods(pods []string, all bool, h PodLister) ([]v1.Pod, error) {
67     		podList, err := h.List(context.Background(), metav1.ListOptions{})
68     		if err != nil {
69     			return nil, err
70     		}
71     		if all {
72     			return podList.Items, nil
73     		}
74     		resp := []v1.Pod{}
75     		for _, pod := range podList.Items {
76     			if isInArray(pod.Name, pods) {
77     				resp = append(resp, pod)
78     			}
79     		}
80     		return resp, nil
81     	}


28     	func SetupEphemeralContainers(pods []v1.Pod, h KubeEphemeralHandler, opts AgentOpts) error {
29     		wg := sync.WaitGroup{}
30     		errchan := make(chan error, len(pods))
31     		wg.Add(len(pods))
32     	
33     		readychan := make(chan bool, len(pods))
34     		c := 0
35     		w := wow.New(os.Stderr, spin.Get(spin.GrowHorizontal), fmt.Sprintf("Creating debug container %d/%d", c, len(pods)))
36     		w.Start()
37     		defer w.Stop()
38     		go func() {
39     			for {
40     				<-readychan
41     				c++
42     				w.Text(fmt.Sprintf("Creating debug container %d/%d", c, len(pods)))
43     			}
44     		}()
45     	
46     		for _, kpturePod := range pods {
47     			n := kpturePod
48     			go func() {
49     				createDebugContainer(n, errchan, &wg, h, opts)
50     				readychan <- true
51     			}()
52     		}
53     		wg.Wait()
54     		w.PersistWith(spin.Spinner{}, fmt.Sprintf("Created debug container %d/%d", len(pods), len(pods)))
55     		log.Println("All debug containers are ready")
56     		for len(errchan) > 0 {
57     			err := <-errchan
58     			if err != nil {
59     				logrus.Error(err)
60     				return err
61     			}
62     		}
63     		return nil
64     	}


21     	func SetupProxy(h KubeProxyHandler, opts ProxyOpts) (string, error) {
22     		name := "kpture-proxy-" + opts.UUID
23     		pod := v1.Pod{
24     			ObjectMeta: metav1.ObjectMeta{
25     				Name:      name,
26     				Namespace: "default",
27     			},
28     			Spec: v1.PodSpec{
29     				Containers: []v1.Container{
30     					{
31     						Name:            "kpture-proxy",
32     						ImagePullPolicy: v1.PullAlways,
33     						Image:           "ghcr.io/gmtstephane/kpture_proxy:latest",
34     						Args:            []string{"proxy"},
35     						Ports: []v1.ContainerPort{
36     							{
37     								Name:          "grpc",
38     								ContainerPort: opts.ServerPort,
39     								Protocol:      v1.ProtocolTCP,
40     							},
41     						},
42     						LivenessProbe: &v1.Probe{
43     							InitialDelaySeconds: livenessProbeInitialDelay,
44     							ProbeHandler: v1.ProbeHandler{
45     								GRPC: &v1.GRPCAction{
46     									Port: opts.ServerPort,
47     								},
48     							},
49     						},
50     						ReadinessProbe: &v1.Probe{
51     							InitialDelaySeconds: readinessProbeInitialDelay,
52     							ProbeHandler: v1.ProbeHandler{
53     								GRPC: &v1.GRPCAction{
54     									Port:    opts.ServerPort,
55     									Service: nil,
56     								},
57     							},
58     						},
59     					},
60     				},
61     			},
62     		}
63     		_, err := h.Create(context.TODO(), &pod, metav1.CreateOptions{})
64     		if err != nil {
65     			return "", err
66     		}
67     	
68     		ctx, cancel := context.WithTimeout(context.Background(), opts.SetupTimeout)
69     		defer cancel()
70     		for {
71     			select {
72     			case <-ctx.Done():
73     				return "", ctx.Err()
74     			default:
75     				j, errgetPod := h.Get(context.Background(), name, metav1.GetOptions{})
76     				if errgetPod != nil {
77     					return "", errgetPod
78     				}
79     				if j.Status.Phase == v1.PodRunning {
80     					return j.Status.PodIP, nil
81     				}
82     			}
83     		}
84     	}


86     	func TearDownProxy(id string, h KubeProxyHandler) error {
87     		return h.Delete(context.Background(), "kpture-proxy-"+id, metav1.DeleteOptions{})
88     	}


