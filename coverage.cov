 90     	func getFreePort() (int, error) {
 91     		addr, err := net.ResolveTCPAddr("tcp", "localhost:0")
 92     		if err != nil {
 93 MISS			return 0, err
 94     		}
 95     	
 96     		l, err := net.ListenTCP("tcp", addr)
 97     		if err != nil {
 98 MISS			return 0, err
 99     		}
100     		defer l.Close()
101     		return l.Addr().(*net.TCPAddr).Port, nil
102     	}


101     	func injectContainer(pod v1.Pod, h KubeEphemeralHandler, opts AgentOpts, id string) error {
102     		// get the pod to make sure we have the latest version
103     		// otherwise we might get a conflict error
104     		syncpod, err := h.Get(context.Background(), pod.Name, metav1.GetOptions{})
105     		if err != nil {
106     			return err
107     		}
108     	
109     		debugContainer := debugContainer(syncpod, "kpture-"+id, opts)
110     	
111     		_, err = h.UpdateEphemeralContainers(context.Background(), pod.Name, debugContainer, metav1.UpdateOptions{})
112     		if err != nil {
113     			return err
114     		}
115     	
116     		return nil
117     	}


83     	func isInArray(s string, array []string) bool {
84     		for _, a := range array {
85     			if a == s {
86     				return true
87     			}
88     		}
89     		return false
90     	}


