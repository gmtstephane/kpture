29     	func NewProxyServer(bufferSize int, cleanup func(wg *sync.WaitGroup, cancel context.CancelFunc)) *Proxy {
30     		s := Proxy{
31     			packets:   make(chan *capture.Packet, bufferSize),
32     			readypods: make([]*capture.Pod, 0),
33     			started:   false,
34     			cleanup:   cleanup,
35     			mu:        sync.Mutex{},
36     			wg:        &sync.WaitGroup{},
37     		}
38     		s.ctx, s.cancel = context.WithCancel(context.Background())
39     		return &s
40     	}


54     	func (s *Proxy) AddPacket(packetStream capture.AgentService_AddPacketServer) error {
55     		logrus.Info("AddPacket")
56     	
57     		s.wg.Add(1)
58     		defer s.wg.Done()
59     	
60     		go func() {
61     			<-s.ctx.Done()
62     			logrus.Info("Context is Done")
63     			if err := packetStream.Send(&capture.Empty{}); err != nil {
64     				logrus.Error(err)
65     			}
66     		}()
67     	
68     		for {
69     			packet, err := packetStream.Recv()
70     			if err != nil {
71     				if errors.Is(err, io.EOF) {
72 MISS					return nil
73     				}
74     				return status.Error(codes.Internal, err.Error())
75     			}
76     	
77     			if s.hasStarted() {
78     				select {
79     				case s.packets <- packet:
80     				default:
81 MISS					logrus.Error("buffer full")
82     				}
83     			}
84     		}
85     	}


 92     	func (s *Proxy) GetPackets(in *capture.Empty, stream capture.ClientService_GetPacketsServer) error {
 93     		logrus.Info("GetPackets")
 94     		s.setStarted()
 95     		for {
 96     			select {
 97     			case <-stream.Context().Done():
 98     				logrus.Info("client stopped connexion, cleaning up...")
 99     				s.cleanup(s.wg, s.cancel)
100     				return nil
101     			case p := <-s.packets:
102     				err := stream.Send(p)
103     				if err != nil {
104 MISS					if errors.Is(err, io.EOF) {
105 MISS						return nil
106     					}
107 MISS					return status.Error(codes.Internal, err.Error())
108     				}
109     			}
110     		}
111     	}


87     	func (s *Proxy) Ready(ctx context.Context, pod *capture.Pod) (*capture.Empty, error) {
88     		s.readypods = append(s.readypods, pod)
89     		return &capture.Empty{}, nil
90     	}


42     	func (s *Proxy) hasStarted() bool {
43     		s.mu.Lock()
44     		defer s.mu.Unlock()
45     		return s.started
46     	}


48     	func (s *Proxy) setStarted() {
49     		s.mu.Lock()
50     		defer s.mu.Unlock()
51     		s.started = true
52     	}

