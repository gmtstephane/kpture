 66     	func createDebugContainer(pod v1.Pod, errchan chan error, wg *sync.WaitGroup, h KubeEphemeralHandler, opts AgentOpts) {
 67     		defer wg.Done()
 68     		err := injectContainer(pod, h, opts, opts.UUID)
 69     		if err != nil {
 70     			errchan <- err
 71     			return
 72     		}
 73     	
 74     		// wait for the debug container to be ready by polling because watch is not implemented for ephemeral containers
 75     		ctx, cancel := context.WithTimeout(context.Background(), opts.SetupTimeout)
 76     		defer cancel()
 77     		for {
 78     			select {
 79     			case <-ctx.Done():
 80     				errchan <- errors.New("timeout waiting for debug container to be ready")
 81     				return
 82     			default:
 83     				pod, errGetPod := h.Get(context.Background(), pod.Name, metav1.GetOptions{})
 84     				if errGetPod != nil {
 85 MISS					errchan <- errGetPod
 86 MISS					return
 87     				}
 88     				for _, eph := range pod.Status.EphemeralContainerStatuses {
 89     					if eph.Name == "kpture-"+opts.UUID {
 90     						if eph.State.Running != nil {
 91     							// log.Println("debug container is Running for pod", pod.Name)
 92     							return
 93     						}
 94     					}
 95     				}
 96     				time.Sleep(defaultPolling)
 97     			}
 98     		}
 99     	}


119     	func debugContainer(pod *v1.Pod, name string, opts AgentOpts) *v1.Pod {
120     		args := []string{
121     			"agent",
122     			fmt.Sprintf("-d%s", opts.Device),
123     			fmt.Sprintf("-t%s", opts.TargetIP),
124     			fmt.Sprintf("-l%d", opts.SnapshotLen),
125     			fmt.Sprintf("-p%d", opts.TargetPort),
126     		}
127     		ec := &v1.EphemeralContainer{
128     			EphemeralContainerCommon: v1.EphemeralContainerCommon{
129     				Name:            name,
130     				Args:            args,
131     				Image:           "ghcr.io/gmtstephane/kpture:latest",
132     				ImagePullPolicy: v1.PullAlways,
133     			},
134     			TargetContainerName: pod.Spec.Containers[0].Name,
135     		}
136     		copied := pod.DeepCopy()
137     		copied.Spec.EphemeralContainers = append(copied.Spec.EphemeralContainers, *ec)
138     		return copied
139     	}


