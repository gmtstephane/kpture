28     	func GetClient(namespace string) (*KubeClient, error) {
29     		configFiles := strings.Split(os.Getenv("KUBECONFIG"), ":")
30     		config := clientcmd.NewNonInteractiveDeferredLoadingClientConfig(
31     			&clientcmd.ClientConfigLoadingRules{Precedence: configFiles},
32     			&clientcmd.ConfigOverrides{})
33     	
34     		rawConf, err := config.RawConfig()
35     		if err != nil {
36 MISS			return nil, errors.New("could not get raw config: " + err.Error())
37     		}
38     	
39     		restconf, err := config.ClientConfig()
40     		if err != nil {
41 MISS			return nil, errors.WithMessage(err, "could not generate clientConfig")
42     		}
43     		restconf.RateLimiter = flowcontrol.NewTokenBucketRateLimiter(defaultQPS, defaultBurst)
44     		clientset, err := kubernetes.NewForConfig(restconf)
45     		if err != nil {
46 MISS			return nil, errors.WithMessage(err, "could not create clientset")
47     		}
48     	
49     		if namespace == "" {
50     			namespace = rawConf.Contexts[rawConf.CurrentContext].Namespace
51     			if namespace == "" {
52 MISS				namespace = "default"
53     			}
54     		}
55     		return &KubeClient{
56     			Namespace: namespace,
57     			Clientset: clientset,
58     			RestConf:  restconf,
59     		}, nil
60     	}


25     	func GetKubeForwarder(
26     		r *rest.Config,
27     		path string,
28     		rch, sch chan struct{},
29     		proxyport int32,
30     	) (*portforward.PortForwarder, int, error) {
31     		port, err := getFreePort()
32     		if err != nil {
33 MISS			return nil, 0, err
34     		}
35     	
36     		hostIP := strings.TrimLeft(r.Host, "htps:/")
37     		transport, upgrader, err := spdy.RoundTripperFor(r)
38     		if err != nil {
39 MISS			return nil, 0, err
40     		}
41     	
42     		dialer := spdy.NewDialer(
43     			upgrader,
44     			&http.Client{Transport: transport},
45     			http.MethodPost,
46     			&url.URL{Scheme: "https", Path: path, Host: hostIP},
47     		)
48     	
49     		fw, err := portforward.New(
50     			dialer,
51     			[]string{fmt.Sprintf("%d:%d", port, proxyport)},
52     			sch,
53     			rch,
54     			io.Discard,
55     			os.Stderr,
56     		)
57     		if err != nil {
58 MISS			log.Println(err)
59 MISS			return nil, 0, err
60     		}
61     	
62     		return fw, port, nil
63     	}


